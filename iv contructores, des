SetCatetos(cat1,cat2);
}
void TrianguloRectangulo::SetCatetos(float cat1,float cat2){
CatMayor=Validar(cat1);
CatMenor=Validar(cat2);
if(CatMenor>CatMayor){
    this->CatMayor=Validar(cat2);
    this->CatMenor=Validar(cat1);
}
}
float TrianguloRectangulo::Validar(float num){
if(num>0){
    return num;
}
if(num==0){
    cout<<"error: valor debe ser diferente de 0"<<endl;
