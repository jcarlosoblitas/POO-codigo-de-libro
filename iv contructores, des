Hora Hora::GetSuma(Hora h){
Hora r;
int tmp=0;
r.seg=seg+h.seg;
if(r.seg>=60){
    tmp=r.seg/60;
    r.seg=r.seg%60;
}
r.minu=minu+h.minu+tmp;
tmp=0;
if(r.minu>=60){
    tmp=r.minu/60;
    r.minu=r.minu%60;
}
r.hora=hora+h.hora+tmp;
return r;
}
Hora Hora::GetSumaSegundos(int s){
Hora r;
int tmp=0;
r.seg=seg+s;
if(r.seg>=60){
    tmp=r.seg/60;
    r.seg=r.seg%60;
}
r.minu=minu+tmp;
tmp=0;
if(r.minu>=60){
    tmp=r.minu/60;
    r.minu=r.minu%60;
}
r.hora=hora+tmp;
return r;
}
