#include<iostream>
#include<cmath>
using namespace std;
class TrianguloRectangulo{
private:
    int cat1;
    int cat2;
public:
    TrianguloRectangulo();
    TrianguloRectangulo(int a,int b);
    float Hipotenusa();
    float Area();
    float Perimetro();
    void mostrar();
};
TrianguloRectangulo::TrianguloRectangulo(){
cat1=0;
cat2=0;
}
TrianguloRectangulo::TrianguloRectangulo(int a,int b){
cat1=a;
cat2=b;
}
float TrianguloRectangulo::Hipotenusa(){
return sqrt((cat1*cat1)+(cat2*cat2));
}
float TrianguloRectangulo::Area(){
return cat1*cat2;
}
float TrianguloRectangulo::Perimetro(){
return cat1+cat2+Hipotenusa();
}
void TrianguloRectangulo::mostrar(){
cout<<"lados..."<<endl;
cout<<"cat1 "<<cat1<<endl;
cout<<"cat2 "<<cat2<<endl;
cout<<"hipetenusa "<<Hipotenusa()<<endl;
cout<<"area "<<Area()<<endl;
cout<<"perimetro "<<Perimetro()<<endl;
}
int main(){
 TrianguloRectangulo t(2,3);
 t.mostrar();
return 1;
 }


