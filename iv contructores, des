    float GetDiagonalMenor();
    void mostrar();
};
TrapecioRectangular::TrapecioRectangular(){
B=b=h=0;
}
TrapecioRectangular::TrapecioRectangular(float B,float b,float h){
SetBases(B,b);
SetAltura(h);
}
void TrapecioRectangular::SetBases(float B,float b){
this->B=Validar(B);
this->b=Validar(b);
if(b>B){
    this->B=Validar(b);
    this->b=Validar(B);
}
}
void TrapecioRectangular::SetAltura(float h){
this->h=Validar(h);
}
float TrapecioRectangular::Validar(float num){
if(num>0){
    return num;
}
if(num==0){
    cout<<"error: valor debe ser direfente de 0"<<endl;
    return -num;
}
}
float TrapecioRectangular::GetBaseMayor(){
return B;
}
float TrapecioRectangular::GetBaseMenor(){
return b;
}
float TrapecioRectangular::GetAltura(){
return h;
}
TrapecioRectangular TrapecioRectangular::GetTrapecio(){
return *this;
}
float TrapecioRectangular::GetArea(){
return h*b+h*(B-b);
}
float TrapecioRectangular::GetCuartoLado(){
return sqrt(h*h+(B-b)*(B-b));
}
float TrapecioRectangular::GetPerimetro(){
return B+b+h+GetCuartoLado();
}
float TrapecioRectangular::GetDiagonalMayor(){
return sqrt(h*h+B*B);
}
float TrapecioRectangular::GetDiagonalMenor(){
return sqrt(h*h+b*b);
}
