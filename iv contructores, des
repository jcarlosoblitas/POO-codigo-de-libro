#include<iostream>
#include<cmath>
using namespace std;
class Punto2D{
private:
    float x;
    float y;
public:
    Punto2D();
    Punto2D( float px,float py);
    Punto2D(const Punto2D&p2d);
    void SetPunto(float px,float py);
    void SetPunto(const Punto2D&p2d);
    void SetX(float px);
    void SetY(float py);
    float GetX();
    float GetY();
    float GetDistancia();
    float GetAreaTriangulo();
    int GetCuadrante();
    float GetAnguloX();
    float GetAnguloY();
    void mostrar();
};
Punto2D::Punto2D(){
x=0;
y=0;
}
Punto2D::Punto2D(float px,float py){
x=px;
y=py;
}
Punto2D::Punto2D(const Punto2D&p2d){
*this=p2d;
}
void Punto2D::SetPunto(float px,float py){
x=px;
y=py;
}
void Punto2D::SetPunto(const Punto2D&p2d){
*this=p2d;
}
void Punto2D::SetX(float px){
x=px;
}
void Punto2D::SetY(float py){
y=py;
}
float Punto2D::GetX(){
return x;
}
float Punto2D::GetY(){
return y;
}
float Punto2D::GetDistancia(){
return sqrt(x*x+y*y);
}
float Punto2D::GetAreaTriangulo(){
return x*y;
}
int Punto2D::GetCuadrante(){
if(x>=0 && y>=0)
{
    return 1;
}
if(x<=0&&y>=0)
{
    return 2;
}
if(x<=0&&y<=0)
{
    return 3;
}
if(x<=0&&y<=0)
{
    return 4;
}
}
float Punto2D::GetAnguloX(){
return atan(y/x)*180/M_PI;
}
float Punto2D::GetAnguloY(){
return 90-GetAnguloX();
}
void Punto2D::mostrar(){
cout<<"("<<x<<","<<y<<")"<<endl;
}

int main(){
 Punto2D p(3,4);
 cout<<p.GetAnguloX()<<endl;
 cout<<p.GetAnguloY()<<endl;
 p.mostrar();
return 1;
 }
