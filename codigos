    void AsignarPunto(int x,int y);
    float Distancia();
    void mostrar();
};
void Punto::AsignarPunto(int x,int y){
this->x=x;
this->y=y;
}
float Punto::Distancia(){
return sqrt(x*x+y*y);
}
void Punto::mostrar(){
cout<<"("<<x<<","<<y<<")"<<endl;
cout<<"distancia del origen al punto ";
cout<<Distancia()<<endl<<endl;
}
