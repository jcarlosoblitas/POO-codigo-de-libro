 #include<iostream>
#include<cmath>
using namespace std;

class Triangulo{
private:
    int a;
    int b;
    int c;
public:
    void Asignarlados(int la,int lb,int lc);
    float Area();
    float Perimetro();
    void mostrar();
};
void Triangulo::Asignarlados(int la,int lb,int lc)
{
    a=la;
    b=lb;
    c=lc;
}
float Triangulo::Area()
{
    float sp=Perimetro()/2;
    return sqrt(sp*(sp-a)*(sp-b)*(sp-c));
}
float Triangulo::Perimetro()
{
    return a+b+c;
}
void Triangulo::mostrar()
{
    cout<<"area ="<<Area()<<"u2"<<endl;
    cout<<"perimetro ="<<Perimetro()<<"u"<<endl;
}
int main(){
    Triangulo p1;
    p1.Asignarlados(3,4,5);
    p1.mostrar();


 return 1;
 }
 
 
 
